{
	"name": "df010UnpivotXfor",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQLUnpivotXfor",
						"type": "DatasetReference"
					},
					"name": "ReadCsv"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQLUnpivot",
						"type": "DatasetReference"
					},
					"name": "sink"
				}
			],
			"transformations": [
				{
					"name": "unpivotdata"
				}
			],
			"scriptLines": [
				"source(output(",
				"          EnglishProductName as string,",
				"          India as double,",
				"          France as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> ReadCsv",
				"ReadCsv unpivot(output(",
				"          Country as string,",
				"          SalesAmount as double",
				"     ),",
				"     ungroupBy(EnglishProductName),",
				"     lateral: true,",
				"     ignoreNullPivots: true) ~> unpivotdata",
				"unpivotdata sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink"
			]
		}
	}
}