{
	"name": "df010UnpivotXfor",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQLUnpivotXfor",
						"type": "DatasetReference"
					},
					"name": "ReadCsv"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "unpivotdata"
				}
			],
			"scriptLines": [
				"source(output(",
				"          EnglishProductName as string,",
				"          India as double,",
				"          France as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> ReadCsv",
				"ReadCsv unpivot(output(",
				"          ",
				"     ),",
				"     lateral: true,",
				"     ignoreNullPivots: false) ~> unpivotdata"
			]
		}
	}
}